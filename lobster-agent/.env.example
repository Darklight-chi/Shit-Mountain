# === LLM Backend (OpenClaw Gateway) ===
OPENAI_BASE_URL=http://localhost:3000/v1
OPENAI_API_KEY=your-openclaw-gateway-token
OPENAI_MODEL=openclaw:default
OPENCLAW_AGENT_ID=

# === Xianyu ===
XIANYU_HEADLESS=false
XIANYU_POLL_INTERVAL=5
XIANYU_MAX_REPLY_LENGTH=500

# === Ozon ===
OZON_CLIENT_ID=
OZON_API_KEY=
OZON_POLL_INTERVAL=10

# === Shopify / Chatwoot bridge adapters ===
SHOPIFY_POLL_INTERVAL=8
SHOPIFY_INBOX_PATH=storage/channels/shopify_inbox.jsonl
SHOPIFY_OUTBOX_PATH=storage/channels/shopify_outbox.jsonl
CHATWOOT_POLL_INTERVAL=5
CHATWOOT_INBOX_PATH=storage/channels/chatwoot_inbox.jsonl
CHATWOOT_OUTBOX_PATH=storage/channels/chatwoot_outbox.jsonl

# === Database ===
# DATABASE_URL=sqlite:///storage/lobster.db

# === General ===
LOG_LEVEL=INFO
DEFAULT_LOCALE=zh

# === Anti-detection ===
STEALTH_ENABLED=true
HUMAN_TYPING_DELAY=80
