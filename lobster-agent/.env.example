# === LLM Backend (OpenClaw Gateway) ===
# OpenClaw gateway URL — change host/port to match your setup
OPENAI_BASE_URL=http://localhost:3000/v1
OPENAI_API_KEY=your-openclaw-gateway-token
OPENAI_MODEL=openclaw:default
# Optional: target a specific OpenClaw agent
OPENCLAW_AGENT_ID=

# === Xianyu ===
XIANYU_HEADLESS=false
XIANYU_POLL_INTERVAL=5
XIANYU_MAX_REPLY_LENGTH=500

# === Ozon (future) ===
OZON_CLIENT_ID=
OZON_API_KEY=

# === Database ===
# DATABASE_URL=sqlite:///storage/lobster.db

# === General ===
LOG_LEVEL=INFO
DEFAULT_LOCALE=zh

# === Anti-detection ===
STEALTH_ENABLED=true
HUMAN_TYPING_DELAY=80
